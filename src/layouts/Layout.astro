---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fran & Gema — 19 de septiembre de 2026",
  description = "Nos complace invitarte a celebrar nuestra boda en Córdoba."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://fran-y-gema.vercel.app");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="FRN.Q Studio" />
    <meta name="theme-color" content="#0A0A0A" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>

    <slot name="head" />
  </head>
  <body>
    <!-- Film Grain -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <!-- Viewport Frame -->
    <div class="viewport-frame" aria-hidden="true">
      <span class="viewport-frame__corner viewport-frame__corner--tl"></span>
      <span class="viewport-frame__corner viewport-frame__corner--tr"></span>
      <span class="viewport-frame__corner viewport-frame__corner--bl"></span>
      <span class="viewport-frame__corner viewport-frame__corner--br"></span>
    </div>

    <!-- Monogram Watermark -->
    <div class="monogram-watermark" aria-hidden="true">F&amp;G</div>

    <!-- FAST Cinematic Preloader — CSS only, 2.5s total -->
    <div class="preloader" id="preloader">
      <div class="preloader__content">
        <div class="preloader__names">
          <span class="preloader__char">F</span>
          <span class="preloader__char preloader__char--gold">&amp;</span>
          <span class="preloader__char">G</span>
        </div>
        <div class="preloader__line"></div>
        <p class="preloader__date">19 &middot; 09 &middot; 2026</p>
        <p class="preloader__loc">Córdoba</p>
      </div>
      <div class="preloader__shutter preloader__shutter--top"></div>
      <div class="preloader__shutter preloader__shutter--bottom"></div>
    </div>

    <!-- Floating Decorative Elements -->
    <div class="float-decor float-decor--circle-1" data-float aria-hidden="true"></div>
    <div class="float-decor float-decor--circle-2" data-float aria-hidden="true"></div>
    <div class="float-decor float-decor--line-1" data-float aria-hidden="true"></div>
    <div class="float-decor float-decor--line-2" data-float aria-hidden="true"></div>
    <div class="float-decor float-decor--ring-1" data-float aria-hidden="true"></div>

    <!-- Navigation -->
    <nav class="site-nav" id="siteNav" aria-label="Navegación">
      <a href="#hero" class="site-nav__brand">F&amp;G</a>
      <div class="site-nav__links">
        <a href="#bienvenida" class="site-nav__link">Bienvenida</a>
        <a href="#dia" class="site-nav__link">El Día</a>
        <a href="#detalles" class="site-nav__link">Detalles</a>
        <a href="#confirma" class="site-nav__link">Confirma</a>
      </div>
    </nav>

    <slot />

    <script src="/scripts/animations.js" is:inline></script>
  </body>
</html>

<style>
  html, body { margin: 0; width: 100%; min-height: 100%; }
</style>