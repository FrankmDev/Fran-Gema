---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero.jpg';

---

<Layout>
  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="hero" id="hero" aria-label="Bienvenida">
    <div class="hero__media" data-parallax>
      <Image
        src={heroImg}
        alt="Fran y Gemma - Pareja de novios"
        widths={[640, 960, 1200, 1920]}
        sizes="100vw"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="hero__image"
      />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__bg-monogram" aria-hidden="true">F&amp;G</div>

    <!-- Hero atmosphere -->
    <div class="hero__atmosphere" aria-hidden="true">
      <div class="hero__lens-flare"></div>
      <div class="hero__dust">
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    </div>

    <div class="hero__content">
      <p class="hero__pretitle" data-reveal="up">Nos casamos</p>
      <h1 class="hero__names" data-reveal="text">
        <span class="text-reveal__inner">Fran <span class="hero__ampersand">&amp;</span> Gemma</span>
      </h1>
      <p class="hero__date" data-reveal="up" data-delay="0.3">
        19 de septiembre de 2026
      </p>
      <p class="hero__location" data-reveal="up" data-delay="0.45">
        Córdoba
      </p>
      <span class="gold-line hero__line" data-reveal="line" data-delay="0.6"></span>
    </div>
    <div class="hero__scroll-hint" aria-hidden="true">
      <span class="hero__scroll-hint-text">Scroll</span>
      <span></span>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WELCOME / QUOTE                              -->
  <!-- ============================================ -->
  <section class="section welcome" id="bienvenida" aria-label="Bienvenida">
    <div class="welcome__bg-monogram" aria-hidden="true">F&amp;G</div>
    <div class="welcome__particles" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="float-decor float-decor--circle-1" data-float></div>
    <div class="welcome__inner">
      <span class="welcome__quote-mark" aria-hidden="true" data-reveal="up">"</span>
      <blockquote class="welcome__quote" data-reveal="text">
        <span class="text-reveal__inner">El amor no tiene cura, pero es la única cura para todos los males.</span>
      </blockquote>
      <cite class="welcome__author" data-reveal="up">— Leonardo da Vinci</cite>
      <div class="welcome__divider" data-reveal="line"></div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- EL DÍA — Alternating Vertical Timeline       -->
  <!-- ============================================ -->
  <section class="section dia" id="dia" aria-labelledby="dia-title">
    <div class="dia__bg-gradient" aria-hidden="true"></div>
    <div class="dia__texture" aria-hidden="true"></div>
    <div class="float-decor float-decor--line-1" data-float></div>
    <div class="float-decor float-decor--ring-2" data-float></div>
    <div class="dia__inner">
      <div class="dia__header">
        <p class="dia__label" data-reveal="up">El Gran Día</p>
        <h2 class="dia__title" id="dia-title" data-reveal="text">
          <span class="text-reveal__inner">19 de septiembre</span>
        </h2>
        <p class="dia__subtitle" data-reveal="up">
          Te esperamos en Córdoba para celebrar juntos este momento tan especial.
        </p>
      </div>

      <div class="dia__timeline" data-timeline>
        <!-- Central spine -->
        <div class="dia__spine" aria-hidden="true">
          <div class="dia__spine-line"></div>
        </div>

        <!-- Event 1: Ceremony — TEXT left | IMAGE right -->
        <div class="dia__event dia__event--left" data-timeline-event="left">
          <span class="dia__event-number" aria-hidden="true">01</span>
          <div class="dia__event-node" aria-hidden="true">
            <span class="dia__node-core"></span>
            <span class="dia__node-ring"></span>
            <span class="dia__node-ring--slow"></span>
          </div>
          <!-- Text card -->
          <div class="dia__event-col dia__event-col--text" data-stagger>
            <div class="dia__event-card">
              <!-- Decorative layers -->
              <span class="dia__event-card-watermark" aria-hidden="true">F&amp;G</span>
              <span class="dia__event-card-shine" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--tl" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--tr" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--bl" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--br" aria-hidden="true"></span>
              <div class="dia__event-card-accent" aria-hidden="true"></div>
              <div class="dia__event-card-frame" aria-hidden="true"></div>
              <div class="dia__event-card-frame--inner" aria-hidden="true"></div>

              <!-- Content -->
              <div class="dia__event-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 3l9 7.5V21H3v-10.5L12 3z"/>
                  <path d="M12 8v5"/>
                  <circle cx="12" cy="16" r="1"/>
                </svg>
              </div>

              <div class="dia__event-meta">
                <span class="dia__event-time">18:30</span>
                <span class="dia__event-ampm">h</span>
              </div>

              <span class="dia__event-category" aria-hidden="true">Ceremonia</span>

              <h3 class="dia__event-name" data-reveal="text">
                <span class="text-reveal__inner">La Ceremonia</span>
              </h3>

              <div class="dia__event-divider" aria-hidden="true">
                <span class="dia__event-divider-ring"></span>
              </div>

              <p class="dia__event-place">Iglesia de Nuestra Señora de Gracia</p>
              <p class="dia__event-address">Plaza del Cristo de Gracia, Córdoba</p>

              <div class="dia__event-link-wrap">
                <span class="dia__event-link-ornament" aria-hidden="true"></span>
                <a
                  href="https://maps.google.com/?q=Iglesia+de+Nuestra+Señora+de+Gracia+Plaza+Cristo+de+Gracia+Cordoba"
                  class="link-underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Ver ubicación <span class="arrow">→</span>
                </a>
              </div>
            </div>
          </div>
          <!-- Image -->
          <div class="dia__event-col dia__event-col--media">
            <div class="dia__event-media" data-mask-reveal>
              <img
                src="/iglesia.jpg"
                alt="Exterior de la Iglesia de Nuestra Señora de Gracia en Córdoba"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="dia__event-img"
              />
              <div class="dia__event-media-frame" aria-hidden="true"></div>
            </div>
          </div>
        </div>

        <!-- Event 2: Reception — IMAGE left | TEXT right -->
        <div class="dia__event dia__event--right" data-timeline-event="right">
          <span class="dia__event-number" aria-hidden="true">02</span>
          <div class="dia__event-node" aria-hidden="true">
            <span class="dia__node-core"></span>
            <span class="dia__node-ring"></span>
            <span class="dia__node-ring--slow"></span>
          </div>
          <!-- Image -->
          <div class="dia__event-col dia__event-col--media">
            <div class="dia__event-media" data-mask-reveal>
              <img
                src="/crisol.jpeg"
                alt="Jardines del salón de banquetes Crisol Jardines de Córdoba"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="dia__event-img"
              />
              <div class="dia__event-media-frame" aria-hidden="true"></div>
            </div>
          </div>
          <!-- Text card -->
          <div class="dia__event-col dia__event-col--text" data-stagger>
            <div class="dia__event-card">
              <!-- Decorative layers -->
              <span class="dia__event-card-watermark" aria-hidden="true">F&amp;G</span>
              <span class="dia__event-card-shine" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--tl" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--tr" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--bl" aria-hidden="true"></span>
              <span class="dia__event-card-corner dia__event-card-corner--br" aria-hidden="true"></span>
              <div class="dia__event-card-accent" aria-hidden="true"></div>
              <div class="dia__event-card-frame" aria-hidden="true"></div>
              <div class="dia__event-card-frame--inner" aria-hidden="true"></div>

              <!-- Content -->
              <div class="dia__event-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                  <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                  <line x1="9" y1="9" x2="9.01" y2="9"/>
                  <line x1="15" y1="9" x2="15.01" y2="9"/>
                </svg>
              </div>

              <div class="dia__event-meta">
                <span class="dia__event-time dia__event-time--text">Después de la misa</span>
              </div>

              <span class="dia__event-category" aria-hidden="true">Celebración</span>

              <h3 class="dia__event-name" data-reveal="text">
                <span class="text-reveal__inner">El Convite</span>
              </h3>

              <div class="dia__event-divider" aria-hidden="true">
                <span class="dia__event-divider-ring"></span>
              </div>

              <p class="dia__event-place">Crisol Jardines de Córdoba</p>
              <p class="dia__event-address">Paseo de la Victoria, s/n, Córdoba</p>

              <div class="dia__event-link-wrap">
                <span class="dia__event-link-ornament" aria-hidden="true"></span>
                <a
                  href="https://maps.google.com/?q=Crisol+Jardines+de+Cordoba+Paseo+de+la+Victoria+Cordoba"
                  class="link-underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Ver ubicación <span class="arrow">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- DETALLES                                     -->
  <!-- ============================================ -->
  <section class="section detalles" id="detalles" aria-labelledby="detalles-title">
    <div class="detalles__bg-monogram" aria-hidden="true">F&amp;G</div>
    <div class="detalles__particles" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span>
    </div>
    <div class="float-decor float-decor--line-2" data-float></div>
    <div class="float-decor float-decor--circle-2" data-float></div>
    <div class="detalles__inner">
      <div class="detalles__header">
        <p class="detalles__label" data-reveal="up">Una noche para recordar</p>
        <h2 class="detalles__title" id="detalles-title" data-reveal="text">
          <span class="text-reveal__inner">Todo lo que necesitas saber</span>
        </h2>
        <p class="detalles__subtitle" data-reveal="up">
          Queremos que disfrutes al máximo de este día tan especial.
        </p>
      </div>

      <div class="detalles__grid" data-stagger-grid>
        <div class="detalles__item" data-reveal="up">
          <span class="detalles__item-corner detalles__item-corner--tl" aria-hidden="true"></span>
          <span class="detalles__item-corner detalles__item-corner--br" aria-hidden="true"></span>
          <div class="detalles__item-icon" data-icon-reveal>&ldquo;</div>
          <p class="detalles__item-title">Vestimenta</p>
          <p class="detalles__item-text">
            Etiqueta formal. Evita el color blanco y tonos muy claros. Opta por colores vivos y elegantes.
          </p>
        </div>
        <div class="detalles__item" data-reveal="up">
          <span class="detalles__item-corner detalles__item-corner--tl" aria-hidden="true"></span>
          <span class="detalles__item-corner detalles__item-corner--br" aria-hidden="true"></span>
          <div class="detalles__item-icon" data-icon-reveal>&#9835;</div>
          <p class="detalles__item-title">Música</p>
          <p class="detalles__item-text">
            ¿Tienes una canción imprescindible para la fiesta? Escríbenos y la incluiremos en la lista.
          </p>
        </div>
        <div class="detalles__item" data-reveal="up">
          <span class="detalles__item-corner detalles__item-corner--tl" aria-hidden="true"></span>
          <span class="detalles__item-corner detalles__item-corner--br" aria-hidden="true"></span>
          <div class="detalles__item-icon" data-icon-reveal>&sect;</div>
          <p class="detalles__item-title">Confirmación</p>
          <p class="detalles__item-text">
            Confirma tu asistencia antes del 1 de agosto. Escríbenos por WhatsApp a cualquiera de nosotros.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CONFIRMA — Royal Invitation Card             -->
  <!-- ============================================ -->
  <section class="section confirma" id="confirma" aria-labelledby="confirma-title">
    <div class="float-decor float-decor--ring-1" data-float></div>
    <div class="confirma__particles" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span>
    </div>
    <div class="confirma__inner">
      <div class="confirma__parchment" data-reveal="up" data-card-3d>
        <!-- Paper texture overlay -->
        <div class="confirma__paper-texture" aria-hidden="true"></div>

        <!-- Ornamental corner flourishes -->
        <span class="confirma__ornament confirma__ornament--tl" aria-hidden="true">
          <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1"><path d="M0 20 Q0 0 20 0 M10 0 Q0 0 0 10"/><path d="M0 40 Q0 60 20 60 M10 60 Q0 60 0 50"/></svg>
        </span>
        <span class="confirma__ornament confirma__ornament--tr" aria-hidden="true">
          <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1"><path d="M60 20 Q60 0 40 0 M50 0 Q60 0 60 10"/><path d="M60 40 Q60 60 40 60 M50 60 Q60 60 60 50"/></svg>
        </span>
        <span class="confirma__ornament confirma__ornament--bl" aria-hidden="true">
          <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1"><path d="M0 40 Q0 60 20 60 M10 60 Q0 60 0 50"/><path d="M0 20 Q0 0 20 0 M10 0 Q0 0 0 10"/></svg>
        </span>
        <span class="confirma__ornament confirma__ornament--br" aria-hidden="true">
          <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1"><path d="M60 40 Q60 60 40 60 M50 60 Q60 60 60 50"/><path d="M60 20 Q60 0 40 0 M50 0 Q60 0 60 10"/></svg>
        </span>

        <!-- Double inner ornamental frame -->
        <span class="confirma__frame" aria-hidden="true"></span>
        <span class="confirma__frame--inner" aria-hidden="true"></span>

        <!-- Wax seal monogram -->
        <div class="confirma__seal" aria-hidden="true">
          <span class="confirma__seal-wax"></span>
          <span class="confirma__seal-text">F&amp;G</span>
        </div>

        <!-- Shine sweep -->
        <span class="confirma__shine" aria-hidden="true"></span>

        <div class="confirma__editorial">
          <p class="confirma__label" data-reveal="up">Reserva tu plaza</p>
          <h2 class="confirma__title" id="confirma-title" data-reveal="text">
            <span class="text-reveal__inner">Confírmanos<br />tu asistencia</span>
          </h2>

          <div class="confirma__divider-gold" data-reveal="line" aria-hidden="true"></div>

          <p class="confirma__body" data-reveal="up">
            Escríbenos por WhatsApp con la mayor brevedad posible para que podamos organizar todo a la perfección.
          </p>

          <!-- Elegant deadline line -->
          <div class="confirma__deadline" data-reveal="up" aria-hidden="true">
            <span class="confirma__deadline-line"></span>
            <span class="confirma__deadline-ornament">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1"><circle cx="6" cy="6" r="5"/></svg>
            </span>
            <span class="confirma__deadline-text">Fecha límite: 1 de agosto de 2026</span>
            <span class="confirma__deadline-ornament">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1"><circle cx="6" cy="6" r="5"/></svg>
            </span>
            <span class="confirma__deadline-line"></span>
          </div>

          <div class="confirma__details" data-stagger>
            <div class="confirma__detail">
              <span class="confirma__detail-flower" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C12 2 14 6 14 9C14 12 12 14 12 14C12 14 10 12 10 9C10 6 12 2 12 2Z"/><path d="M12 22C12 22 10 18 10 15C10 12 12 10 12 10C12 10 14 12 14 15C14 18 12 22 12 22Z"/><path d="M2 12C2 12 6 10 9 10C12 10 14 12 14 12C14 12 12 14 9 14C6 14 2 12 2 12Z"/><path d="M22 12C22 12 18 14 15 14C12 14 10 12 10 12C10 12 12 10 15 10C18 10 22 12 22 12Z"/></svg>
              </span>
              <span class="confirma__detail-text">Confirma si asistirás a la celebración</span>
            </div>
            <div class="confirma__detail">
              <span class="confirma__detail-flower" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C12 2 14 6 14 9C14 12 12 14 12 14C12 14 10 12 10 9C10 6 12 2 12 2Z"/><path d="M12 22C12 22 10 18 10 15C10 12 12 10 12 10C12 10 14 12 14 15C14 18 12 22 12 22Z"/><path d="M2 12C2 12 6 10 9 10C12 10 14 12 14 12C14 12 12 14 9 14C6 14 2 12 2 12Z"/><path d="M22 12C22 12 18 14 15 14C12 14 10 12 10 12C10 12 12 10 15 10C18 10 22 12 22 12Z"/></svg>
              </span>
              <span class="confirma__detail-text">Indica si tienes alguna intolerancia o alergia alimentaria</span>
            </div>
            <div class="confirma__detail">
              <span class="confirma__detail-flower" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C12 2 14 6 14 9C14 12 12 14 12 14C12 14 10 12 10 9C10 6 12 2 12 2Z"/><path d="M12 22C12 22 10 18 10 15C10 12 12 10 12 10C12 10 14 12 14 15C14 18 12 22 12 22Z"/><path d="M2 12C2 12 6 10 9 10C12 10 14 12 14 12C14 12 12 14 9 14C6 14 2 12 2 12Z"/><path d="M22 12C22 12 18 14 15 14C12 14 10 12 10 12C10 12 12 10 15 10C18 10 22 12 22 12Z"/></svg>
              </span>
              <span class="confirma__detail-text">Dinos si necesitarás alojamiento para esa noche</span>
            </div>
          </div>

          <!-- Ornamental divider -->
          <div class="confirma__ornament-divider" aria-hidden="true">
            <span class="confirma__ornament-divider-line"></span>
            <span class="confirma__ornament-divider-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            </span>
            <span class="confirma__ornament-divider-line"></span>
          </div>

          <div class="confirma__contacts" data-reveal="up">
            <div class="confirma__contact-card">
              <p class="confirma__contact-label">Contacto del novio</p>
              <p class="confirma__contact-name">Fran</p>
              <p class="confirma__contact-phone" data-copy>+34 634 99 11 48</p>
            </div>
            <div class="confirma__contact-connector" aria-hidden="true">&amp;</div>
            <div class="confirma__contact-card">
              <p class="confirma__contact-label">Contacto de la novia</p>
              <p class="confirma__contact-name">Gemma</p>
              <p class="confirma__contact-phone" data-copy>+34 653 99 74 15</p>
            </div>
          </div>

          <div class="confirma__actions" data-reveal="up">
            <a
              href="https://wa.me/34634991148"
              class="confirma__btn-gold"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="confirma__btn-shine" aria-hidden="true"></span>
              <span class="confirma__btn-text">WhatsApp Fran</span>
            </a>
            <a
              href="https://wa.me/34653997415"
              class="confirma__btn-gold"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="confirma__btn-shine" aria-hidden="true"></span>
              <span class="confirma__btn-text">WhatsApp Gemma</span>
            </a>
          </div>

          <!-- Closing sentiment -->
          <div class="confirma__closing" data-reveal="up">
            <span class="confirma__closing-line" aria-hidden="true"></span>
            <p class="confirma__closing-text">Tu presencia será el mejor regalo que podamos recibir</p>
            <span class="confirma__closing-line" aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FOOTER                                       -->
  <!-- ============================================ -->
  <footer class="footer" role="contentinfo">
    <span class="gold-line footer__line" data-reveal="line"></span>
    <p class="footer__names" data-reveal="up">Fran &amp; Gemma</p>
    <p class="footer__date" data-reveal="up">19 de septiembre de 2026 &middot; Córdoba</p>
    <p class="footer__credit" data-reveal="up">
      Diseñado por <a href="https://www.frnq.studio" target="_blank" rel="noopener noreferrer">FRN.Q Studio</a>
    </p>
  </footer>
</Layout>
